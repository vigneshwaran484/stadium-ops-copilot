# ── Gemini API Configuration (Embeddings) ─────────────────────────────────────
GEMINI_API_KEY=GEMINI_API_KEY
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# ── Groq API Configuration (Text Generation) ──────────────────────────────────
GROQ_API_KEY=GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile

# ── Chunking Strategy ────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# ── Retrieval Settings ───────────────────────────────────────────────────────
TOP_K=4

# ── Paths ────────────────────────────────────────────────────────────────────
VECTORSTORE_PATH=./vectorstore
SOP_PATH=./sop_documents
